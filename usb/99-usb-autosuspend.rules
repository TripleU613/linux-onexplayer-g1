# Disable autosuspend for GenesysLogic USB hub (causes freeze/disconnect on G1)
ACTION==add, SUBSYSTEM==usb, ATTR{idVendor}==05e3, ATTR{idProduct}==0610, ATTR{power/control}=on, ATTR{power/autosuspend_delay_ms}=0
# Broadly disable for all USB hubs to prevent input device drops
ACTION==add, SUBSYSTEM==usb, ATTR{bDeviceClass}==09, ATTR{power/control}=on
# Keep AMIRA 2.4GHz receiver powered (no autosuspend) — flaky on G1 USB
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="6080", ATTR{idProduct}=="8060", ATTR{power/control}="on", ATTR{power/autosuspend_delay_ms}="0"
